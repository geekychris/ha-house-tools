[Unit]
Description=Weather forecast fetcher (Open-Meteo -> HA sensors)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/chris/weather
EnvironmentFile=/home/chris/weather/weather.env
ExecStart=/usr/bin/python3 /home/chris/weather/openmeteo.py
User=chris

[Install]
WantedBy=multi-user.target
